APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://ict:ict@db:5432/ict_integration_hub
DOCUMENT_STORAGE_ROOT=var/document_storage
LIVE_CONNECTOR_READONLY=false
PRODUCTION_OPERATIONS_ENABLED=false
PRODUCTION_APPROVAL_ACK=

ODOO_BASE_URL=https://example.odoo.com
ODOO_DATABASE=example
ODOO_API_KEY=change-me
ODOO_TIMEOUT_SECONDS=10
# ODOO_PURCHASE_JOURNAL_ID=1
# ODOO_PURCHASE_JOURNAL_CODE=BILL

UYUMSOFT_ENVIRONMENT=test
UYUMSOFT_TEST_WSDL_URL=https://efatura-test.uyumsoft.com.tr/Services/Integration?wsdl
UYUMSOFT_PROD_WSDL_URL=https://efatura.uyumsoft.com.tr/Services/Integration?wsdl
UYUMSOFT_USERNAME=change-me
UYUMSOFT_PASSWORD=change-me
UYUMSOFT_TIMEOUT_SECONDS=20
UYUMSOFT_RETRY_ATTEMPTS=3
UYUMSOFT_RETRY_BACKOFF_SECONDS=0.2
