APP_ENV=production
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://<db-user>:<db-password>@<db-host>:5432/<db-name>
DOCUMENT_STORAGE_ROOT=/var/lib/ict-integration-hub/document_storage
LIVE_CONNECTOR_READONLY=false
PRODUCTION_OPERATIONS_ENABLED=true
PRODUCTION_APPROVAL_ACK=APPROVED_FOR_PRODUCTION

ODOO_BASE_URL=https://<approved-odoo-host>
ODOO_DATABASE=<odoo-database-name>
ODOO_API_KEY=<odoo-api-key>
ODOO_TIMEOUT_SECONDS=10
ODOO_PURCHASE_JOURNAL_ID=<purchase-journal-id>
ODOO_PURCHASE_JOURNAL_CODE=

UYUMSOFT_ENVIRONMENT=production
UYUMSOFT_TEST_WSDL_URL=https://efatura-test.uyumsoft.com.tr/Services/Integration?wsdl
UYUMSOFT_PROD_WSDL_URL=https://efatura.uyumsoft.com.tr/Services/Integration?wsdl
UYUMSOFT_USERNAME=<uyumsoft-username>
UYUMSOFT_PASSWORD=<uyumsoft-password>
UYUMSOFT_TIMEOUT_SECONDS=20
UYUMSOFT_RETRY_ATTEMPTS=3
UYUMSOFT_RETRY_BACKOFF_SECONDS=0.2
